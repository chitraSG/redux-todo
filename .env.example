# Get these from https://www.emailjs.com/ → Account, Email Services, Email Templates
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=your_service_id

# Newsletter: notify you (To = your inbox). Template body: {{user_email}}, {{subscribed_at}}
VITE_EMAILJS_SUBSCRIBE_TEMPLATE_ID=your_subscribe_template_id

# Optional: welcome email to subscriber (To = {{user_email}})
# VITE_EMAILJS_WELCOME_TEMPLATE_ID=your_welcome_template_id

# Contact form on /help. Template: {{from_name}}, {{reply_to}}, {{subject}}, {{message}}
VITE_EMAILJS_CONTACT_TEMPLATE_ID=your_contact_template_id
